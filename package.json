{
  "name": "local-play-spinner-game",
  "version": "1.0.0",
  "private": true,
  "description": "Local-play two-player spinner game MVP",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
